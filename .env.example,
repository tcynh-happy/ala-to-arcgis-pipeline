# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env file. (.gitignore already excludes it.)

# --- ArcGIS Online credentials (required) ---
ARCGIS_USERNAME=your_arcgis_username
ARCGIS_PASSWORD=your_arcgis_password
ARCGIS_URL=https://www.arcgis.com

# --- Forest boundary Feature Service query endpoint (required) ---
# Kept out of the code so no private location data lives in the repo.
FEATURE_LAYER_URL=https://services3.arcgis.com/XXXXXXXX/arcgis/rest/services/YOUR_LAYER/FeatureServer/1/query

# --- Target layer / output (optional) ---
LAYER_TITLE=ALA_Species_Observations
OUTPUT_CSV=ALA_species.csv

# --- Fetch tuning (optional) ---
ALA_START_YEAR=2000
RECENT_MONTHS=6

# --- Logging (optional): DEBUG, INFO, WARNING, ERROR ---
LOG_LEVEL=INFO
